{
	"type": "SharedSlice",
	"id": "step_card_list",
	"name": "StepCardList",
	"variations": [
		{
			"id": "default",
			"name": "Default",
			"description": "Each item in the list presents a step with an image, number, rich description, button, and associated contact details.",
			"version": "initial",
			"imageUrl": "",
			"docURL": "...",
			"primary": {
				"steps": {
					"type": "Group",
					"config": {
						"label": "Steps",
						"fields": {
							"image": {
								"type": "Image",
								"config": {
									"label": "Image"
								}
							},
							"step_number": {
								"type": "Text",
								"config": {
									"label": "Step Number"
								}
							},
							"description": {
								"type": "StructuredText",
								"config": {
									"multi": "paragraph,strong,em,hyperlink",
									"label": "Description"
								}
							},
							"cta": {
								"type": "Link",
								"config": {
									"label": "Call To Action",
									"allowText": true,
									"repeat": false,
									"select": null
								}
							},
							"contact_name": {
								"type": "Text",
								"config": {
									"label": "Contact Name"
								}
							},
							"contact_role": {
								"type": "Text",
								"config": {
									"label": "Contact Role"
								}
							},
							"contact_email": {
								"type": "Text",
								"config": {
									"label": "Contact Email"
								}
							},
							"contact_phone": {
								"type": "Text",
								"config": {
									"label": "Contact Phone"
								}
							}
						}
					}
				}
			}
		}
	]
}
