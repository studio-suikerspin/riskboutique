{
  "type": "SharedSlice",
  "id": "content_cards_with_image",
  "name": "ContentCardsWithImage",
  "variations": [
    {
      "id": "image_left_text_right",
      "name": "default",
      "description": "Each card displays an image on the left and text content on the right, often used to highlight a category or feature with supporting details.",
      "version": "initial",
      "imageUrl": "",
      "docURL": "...",
      "primary": {
        "headline": {
          "type": "Text",
          "config": {
            "label": "Headline",
            "placeholder": ""
          }
        },
        "subtekst": {
          "type": "StructuredText",
          "config": {
            "label": "subtekst",
            "placeholder": "",
            "allowTargetBlank": true,
            "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
          }
        },
        "call_to_action": {
          "type": "Link",
          "config": {
            "label": "call to action",
            "placeholder": "",
            "select": null,
            "allowTargetBlank": true,
            "allowText": true,
            "repeat": false
          }
        },
        "items": {
          "type": "Group",
          "config": {
            "label": "Cards",
            "fields": {
              "media": {
                "type": "Image",
                "config": {
                  "label": "Image"
                }
              },
              "image_position": {
                "type": "Boolean",
                "config": {
                  "label": "Image position",
                  "placeholder_false": "left",
                  "placeholder_true": "right",
                  "default_value": false
                }
              },
              "title": {
                "type": "Text",
                "config": {
                  "label": "Title",
                  "placeholder": ""
                }
              },
              "description": {
                "type": "StructuredText",
                "config": {
                  "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
                  "label": "Description"
                }
              }
            }
          }
        },
        "section_padding": {
          "type": "Select",
          "config": {
            "label": "Section padding",
            "placeholder": "",
            "options": [
              "top",
              "bottom",
              "both",
              "none"
            ]
          }
        },
        "contact_avatar": {
          "type": "Link",
          "config": {
            "label": "Contact avatar",
            "select": "document",
            "repeat": false,
            "customtypes": [
              {
                "id": "avatar_contact_info",
                "fields": [
                  "image",
                  "name",
                  "role",
                  "phone",
                  "email"
                ]
              }
            ]
          }
        }
      },
      "items": {}
    }
  ]
}